# Nexus CLI Environment Configuration

# GitHub Personal Access Token (Optional, for increased rate limits)
GITHUB_TOKEN=

# OpenWeatherMap API Key (Required for 'weather' command)
OPENWEATHER_API_KEY=

# NewsAPI Key (Required for 'news' command)
NEWS_API_KEY=

# CoinGecko Key (Optional)
COINGECKO_API_KEY=

# Node Environment
NODE_ENV=development

# Meow Mode (Legacy support)
MEOW_MODE=false
